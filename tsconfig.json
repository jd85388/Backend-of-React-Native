{ 
    "compilerOptions" : {
        "target": "es2020",
        "module": "es2020",
        "moduleResolution": "node",
        "outDir":"dist",
        "rootDir":"src",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "strict": false,
        "verbatimModuleSyntax": false,
        "types": ["node","jest"]
        },
        "include": ["src/**/*"],
        "exclude": ["node_modules", "../f/**/*", "../../f/**/*", "../../../f/**/*"]
}