    "compilerOptions" : {
        "target": "es2020",
        "module": "es2020",
        "moduleResolution": "node",
        "outDir":"dist",
        "rootDir":"src",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "strict": true,
        "types": ["node","jest"]
        },
        "include": ["src/**/*"],
        "exclude": ["node_modules"]
}